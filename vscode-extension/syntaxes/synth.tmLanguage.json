{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Synth",
  "scopeName": "source.synth",
  "fileTypes": [
    "syn"
  ],
  "patterns": [
    {
      "include": "#block-comment"
    },
    {
      "include": "#line-comment"
    },
    {
      "include": "#triple-string"
    },
    {
      "include": "#template-literal"
    },
    {
      "include": "#annotation-effects"
    },
    {
      "include": "#annotation-intent"
    },
    {
      "include": "#annotation-flag"
    },
    {
      "include": "#fn-declaration"
    },
    {
      "include": "#record-declaration"
    },
    {
      "include": "#type-declaration"
    },
    {
      "include": "#interface-declaration"
    },
    {
      "include": "#enum-declaration"
    },
    {
      "include": "#control-keywords"
    },
    {
      "include": "#declaration-keywords"
    },
    {
      "include": "#async-keywords"
    },
    {
      "include": "#logical-keywords"
    },
    {
      "include": "#builtin-types"
    },
    {
      "include": "#type-reference"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#string"
    },
    {
      "include": "#number"
    },
    {
      "include": "#pipeline-operator"
    },
    {
      "include": "#nullish-operators"
    },
    {
      "include": "#match-arm-separator"
    },
    {
      "include": "#arrow-lambda"
    },
    {
      "include": "#arrow-return"
    },
    {
      "include": "#type-annotation-sep"
    },
    {
      "include": "#spread"
    },
    {
      "include": "#field-shorthand"
    },
    {
      "include": "#hash-pattern"
    },
    {
      "include": "#comparison-operators"
    },
    {
      "include": "#wildcard"
    }
  ],
  "repository": {
    "block-comment": {
      "name": "comment.block",
      "begin": "/\\*",
      "end": "\\*/",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.comment.begin"
        }
      },
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.comment.end"
        }
      }
    },
    "line-comment": {
      "name": "comment.line.double-slash",
      "match": "//.*$"
    },
    "triple-string": {
      "name": "string.quoted.triple",
      "begin": "\"\"\"",
      "end": "\"\"\"",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin"
        }
      },
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end"
        }
      },
      "patterns": [
        {
          "name": "constant.character.escape",
          "match": "\\\\."
        }
      ]
    },
    "template-literal": {
      "name": "string.template",
      "begin": "`",
      "end": "`",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.template.begin"
        }
      },
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.template.end"
        }
      },
      "patterns": [
        {
          "name": "meta.template.expression",
          "begin": "\\$\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.template-expression.begin"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.template-expression.end"
            }
          },
          "patterns": [
            {
              "include": "#template-expression-inner"
            }
          ]
        },
        {
          "name": "constant.character.escape",
          "match": "\\\\."
        }
      ]
    },
    "template-expression-inner": {
      "patterns": [
        {
          "include": "#line-comment"
        },
        {
          "include": "#string"
        },
        {
          "include": "#number"
        },
        {
          "include": "#constants"
        },
        {
          "include": "#builtin-types"
        },
        {
          "include": "#control-keywords"
        },
        {
          "include": "#declaration-keywords"
        },
        {
          "include": "#comparison-operators"
        }
      ]
    },
    "annotation-effects": {
      "match": "(@effects)\\s*(\\[[^\\]]*\\])?",
      "captures": {
        "1": {
          "name": "storage.modifier.annotation"
        },
        "2": {
          "name": "support.other.effects-list"
        }
      }
    },
    "annotation-intent": {
      "begin": "(@intent)\\s*(\")",
      "end": "\"",
      "beginCaptures": {
        "1": {
          "name": "storage.modifier.annotation"
        },
        "2": {
          "name": "punctuation.definition.string.begin"
        }
      },
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end"
        }
      },
      "contentName": "string.quoted.double.annotation-value"
    },
    "annotation-flag": {
      "name": "storage.modifier.annotation",
      "match": "@(pure|total|memo|exhaustive|test|throws)\\b"
    },
    "fn-declaration": {
      "match": "\\b(async\\s+)?(fn)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)",
      "captures": {
        "1": {
          "name": "keyword.control.async"
        },
        "2": {
          "name": "keyword.declaration.function"
        },
        "3": {
          "name": "entity.name.function"
        }
      }
    },
    "record-declaration": {
      "match": "\\b(record)\\s+([A-Z][a-zA-Z0-9_$]*)",
      "captures": {
        "1": {
          "name": "keyword.declaration.type"
        },
        "2": {
          "name": "entity.name.type"
        }
      }
    },
    "type-declaration": {
      "match": "\\b(type)\\s+([A-Z][a-zA-Z0-9_$]*)",
      "captures": {
        "1": {
          "name": "keyword.declaration.type"
        },
        "2": {
          "name": "entity.name.type"
        }
      }
    },
    "interface-declaration": {
      "match": "\\b(interface)\\s+([A-Z][a-zA-Z0-9_$]*)",
      "captures": {
        "1": {
          "name": "keyword.declaration.type"
        },
        "2": {
          "name": "entity.name.type"
        }
      }
    },
    "enum-declaration": {
      "match": "\\b(enum)\\s+([A-Z][a-zA-Z0-9_$]*)",
      "captures": {
        "1": {
          "name": "keyword.declaration.type"
        },
        "2": {
          "name": "entity.name.type"
        }
      }
    },
    "control-keywords": {
      "name": "keyword.control",
      "match": "\\b(if|else|match|return|while|for|in|break|continue|when)\\b"
    },
    "declaration-keywords": {
      "name": "keyword.other",
      "match": "\\b(let|new|where|mut|refine|infer|store|on|import|export|from|as|module|do|typeof|instanceof)\\b"
    },
    "async-keywords": {
      "name": "keyword.control.async",
      "match": "\\b(async|await)\\b"
    },
    "logical-keywords": {
      "name": "keyword.operator.word",
      "match": "\\b(and|or|not)\\b"
    },
    "builtin-types": {
      "name": "support.type.primitive",
      "match": "\\b(int|float|string|bool|void|any|list)\\b"
    },
    "type-reference": {
      "name": "support.type",
      "match": "\\b([A-Z][a-zA-Z0-9_$]*)\\b"
    },
    "constants": {
      "name": "constant.language",
      "match": "\\b(true|false|null|undefined)\\b"
    },
    "string": {
      "name": "string.quoted.double",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin"
        }
      },
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end"
        }
      },
      "patterns": [
        {
          "name": "meta.interpolation",
          "match": "\\{[a-zA-Z_$][a-zA-Z0-9_$]*(?:\\.[a-zA-Z_$][a-zA-Z0-9_$]*)*\\}",
          "captures": {
            "0": {
              "name": "variable.other.interpolated"
            }
          }
        },
        {
          "name": "constant.character.escape",
          "match": "\\\\."
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "name": "constant.numeric.hex",
          "match": "\\b0x[0-9A-Fa-f_]+\\b"
        },
        {
          "name": "constant.numeric.binary",
          "match": "\\b0b[01_]+\\b"
        },
        {
          "name": "constant.numeric.float",
          "match": "\\b[0-9]+(?:_[0-9]+)*\\.[0-9]+(?:_[0-9]+)*([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer",
          "match": "\\b[0-9]+(?:_[0-9]+)*\\b"
        }
      ]
    },
    "pipeline-operator": {
      "name": "keyword.operator.pipeline",
      "match": "\\|>"
    },
    "nullish-operators": {
      "patterns": [
        {
          "name": "keyword.operator.nullish",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.optional",
          "match": "\\?\\."
        }
      ]
    },
    "match-arm-separator": {
      "name": "punctuation.separator.match-arm",
      "match": "(?<=[\\s{(,])\\|(?!>)|^\\s*\\|(?!>)"
    },
    "arrow-lambda": {
      "name": "keyword.operator.arrow",
      "match": "=>"
    },
    "arrow-return": {
      "name": "keyword.operator.return-type",
      "match": "->"
    },
    "type-annotation-sep": {
      "name": "keyword.operator.type-annotation",
      "match": "::"
    },
    "spread": {
      "name": "keyword.operator.spread",
      "match": "\\.\\.\\."
    },
    "field-shorthand": {
      "name": "variable.other.field-shorthand",
      "match": "(?<=[(,\\s])\\.[a-zA-Z_$][a-zA-Z0-9_$]*(?=[,)\\s])"
    },
    "hash-pattern": {
      "name": "constant.other.pattern-ref",
      "match": "#[a-zA-Z_][a-zA-Z0-9_]*"
    },
    "comparison-operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison",
          "match": "===|!==|>=|<=|>(?!>)|<(?!<)"
        },
        {
          "name": "keyword.operator.logical",
          "match": "&&|\\|\\|"
        },
        {
          "name": "keyword.operator.assignment",
          "match": "(?<!=)=(?![=>])"
        }
      ]
    },
    "wildcard": {
      "name": "variable.language.wildcard",
      "match": "(?<=[\\s|])_(?=[\\s=>]|$)"
    }
  }
}
