{
  "name": "synth-language",
  "displayName": "Synth Language",
  "description": "Syntax highlighting, bracket matching, and language support for the Synth programming language (.syn files)",
  "version": "1.0.4",
  "publisher": "synth-lang",
  "license": "MIT",
  "engines": {
    "vscode": "^1.60.0"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:synth",
    "workspaceContains:**/*.syn"
  ],
  "categories": [
    "Programming Languages"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/synth-pl/synth"
  },
  "contributes": {
    "languages": [
      {
        "id": "synth",
        "aliases": ["Synth", "synth"],
        "extensions": [".syn"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "synth",
        "scopeName": "source.synth",
        "path": "./syntaxes/synth.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[synth]": {
        "editor.semanticHighlighting.enabled": false
      }
    }
  }
}
