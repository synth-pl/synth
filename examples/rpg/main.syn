// ═══════════════════════════════════════════════════════════════════════════════
// Synth v1.0 — RPG Adventure
//
// 50-battle marathon dungeon crawl built entirely in Synth. All game rules — damage,
// elemental bonuses, XP thresholds, stat scaling — live in pure @memo functions.
// The DOM layer is a thin shell: it mounts scenes, wires buttons, and re-renders.
//
// Synth v0.4 features exercised (in addition to all v0.1–v0.3 features):
//   when guards             classify HP status with guarded match arms
//   ?. optional chaining    hero.weapon?.name ?? "bare hands"
//   ?? nullish coalescing   safe fallbacks without verbose ternaries
//   let { } destructuring   unpack damage breakdown into named locals
//   """ triple-quote strings (used in battle intro text)
//   @test declarations      pure rule functions verified at compile-time
//   Tagged unions           GameScene type as safe state machine
//   |> as naming            named pipeline steps in party analysis
// ═══════════════════════════════════════════════════════════════════════════════

// ── Constrained types ─────────────────────────────────────────────────────────

type Gold, XP  = int    where >= 0
type HP        = int    where >= 0 && <= 999
type StatValue = int    where >= 1 && <= 50
type Level     = int    where >= 1 && <= 20
type HeroName, ClassName = string where length > 0

// ── Records ───────────────────────────────────────────────────────────────────

record Hero {
  name: string
  heroClass: string
  hp: int
  maxHp: int
  baseStrength: int
  baseDefense: int
  level: int
  xp: int
  alive: bool
  weapon: Equipment?
  armor: Equipment?
}

record Enemy {
  id: string
  name: string
  hp: int
  maxHp: int
  attack: int
  defense: int
  weakness: string
  xpReward: int
  goldReward: int
  alive: bool
}

record Equipment {
  id: string
  name: string
  slot: string
  atkBonus: int
  defBonus: int
  price: int
  forClass: string
  desc: string
}

record Item {
  id: string
  name: string
  effect: string
  power: int
  price: int
  count: int
}

// ══════════════════════════════════════════════════════════════════════════════
// PURE UTILITY FUNCTIONS
// ══════════════════════════════════════════════════════════════════════════════

@pure @total
fn hp_bar :: (hp: int, maxHp: int) -> string {
  let filled = maxHp > 0 ? Math.max(0, Math.round(hp / maxHp * 10)) : 0
  let bar    = range(0, 10) |> map(i => i < filled ? "#" : ".")
  bar.join("")
}

@pure @total
fn xp_bar :: (xp: int, xpNext: int) -> string {
  let filled = xpNext > 0 ? Math.max(0, Math.round(xp / xpNext * 8)) : 8
  let bar    = range(0, 8) |> map(i => i < filled ? "*" : ".")
  bar.join("")
}

// Index = level (1..14); out-of-range falls back to 99999
let XP_TABLE = [0, 150, 340, 600, 950, 1400, 2000, 2750, 3700, 4900, 6400, 8200, 10500, 13200, 16500]

@intent "XP needed for next level — exponential curve across 15 levels"
@pure @total @memo
fn xp_to_next :: (level: int) -> int {
  level >= 1 and level <= 14 ? XP_TABLE[level] : 99999
}

fn weapon_atk(w) = w ? w.atkBonus : 0
fn armor_def(a)  = a ? a.defBonus  : 0

@pure @total @memo
fn effective_str :: (hero: Hero) -> int {
  hero.baseStrength + weapon_atk(hero.weapon)
}

@pure @total @memo
fn effective_def :: (hero: Hero) -> int {
  hero.baseDefense + armor_def(hero.armor)
}

@pure @total
fn format_hero_line :: (hero: Hero) -> string {
  let bar   = hp_bar(hero.hp, hero.maxHp)
  let title = level_title(hero.heroClass, hero.level)
  let sym   = class_symbol(hero.heroClass)
  "{sym} {hero.name} Lv.{hero.level} {title}  [{bar}] {hero.hp}/{hero.maxHp} HP"
}

@pure @total
fn format_xp_line :: (hero: Hero) -> string {
  let bar  = xp_bar(hero.xp, xp_to_next(hero.level))
  let next = xp_to_next(hero.level)
  "   XP [{bar}] {hero.xp}/{next}"
}

@pure @total
fn format_equip_line :: (hero: Hero) -> string {
  let wName = hero.weapon?.name ?? "bare hands"
  let aName = hero.armor?.name  ?? "no armor"
  "   {wName} / {aName}"
}

// Short-form string templates used throughout the combat log
@pure @total
fn fmt_attack :: (attacker: string, means: string, outcome: string, defender: string, dmg: int) -> string {
  outcome === "misses"
    ? "{attacker} misses {defender} with {means}!"
    : "{attacker} {outcome} {defender} with {means} for {dmg}!"
}

@intent "Breakdown line — power, armor mitigation, crit, final damage"
@pure @total
fn fmt_dmg_detail :: (atk: int, bonus: int, mitigation: int, source: string, isCrit: bool, finalDmg: int) -> string {
  let powerPart = bonus > 0 ? "ATK {atk} + elem {bonus}" : "ATK {atk}"
  let armorPart = mitigation > 0 ? ", {source} -{mitigation}" : ", no armor reduction"
  let critPart  = isCrit ? ", critical x2" : ""
  "  [{powerPart}{armorPart}{critPart} → {finalDmg} dmg]"
}

fn fmt_death(name)          = "  {name} has fallen."
fn fmt_level_up(name, lv)   = "** {name} reached level {lv}! **"
fn fmt_heal(name, item, hp) = "  {name} drinks {item}, restoring {hp} HP."
fn fmt_revive(name, item)   = "  {name} is revived by {item}!"

// Weapon name for knights/rangers; spell name for mages (tied to equipped focus)
@pure @total
fn mage_spell :: (weaponId: string) -> string {
  match weaponId {
    | "app_staff"    => "Spark Bolt"
    | "arcane_staff" => "Arcane Lance"
    | "arcane_tome"  => "Rune Barrage"
    | "soul_staff"   => "Soulfire"
    | _              => "Magic Missile"
  }
}

@intent "What the hero attacks with — weapon for martial classes, spell for mages"
@pure @total
fn attack_means :: (hero: Hero) -> string {
  match hero.heroClass {
    | "mage" => hero.weapon?.id ? mage_spell(hero.weapon.id) : "Magic Missile"
    | _      => hero.weapon?.name ?? "bare hands"
  }
}

// ══════════════════════════════════════════════════════════════════════════════
// PATTERN MATCHING FUNCTIONS
// ══════════════════════════════════════════════════════════════════════════════

@intent "Class-specific rank titles by level band"
@pure @total
fn level_title :: (heroClass: string, level: int) -> string {
  match heroClass {
    | "mage" => match level {
      | < 3  => "Apprentice"
      | < 6  => "Adept"
      | < 9  => "Evoker"
      | < 12 => "Archmage"
      | _    => "Archon"
    }
    | "knight" => match level {
      | < 3  => "Squire"
      | < 6  => "Knight"
      | < 9  => "Champion"
      | < 12 => "Paladin"
      | _    => "Paragon"
    }
    | "ranger" => match level {
      | < 3  => "Scout"
      | < 6  => "Tracker"
      | < 9  => "Hunter"
      | < 12 => "Warden"
      | _    => "Pathfinder"
    }
    | _ => match level {
      | < 3  => "Novice"
      | < 6  => "Adept"
      | < 9  => "Veteran"
      | < 12 => "Hero"
      | _    => "Legend"
    }
  }
}

@pure @total
fn class_symbol :: (heroClass: string) -> string {
  match heroClass {
    | "mage"   => "[M]"
    | "knight" => "[K]"
    | "ranger" => "[R]"
    | _        => "[?]"
  }
}

@pure @total
fn combat_outcome_label :: (roll: int) -> string {
  match roll {
    | >= 20 => "PERFECT STRIKE on"
    | >= 18 => "CRITICAL HIT on"
    | >= 8  => "hits"
    | >= 3  => "grazes"
    | _     => "misses"
  }
}

// v0.4: when-guarded match — HP status label with ratio thresholds
@intent "v0.4 when guards — classify HP as a ratio, one expressive match"
@pure @total
fn hp_status_label :: (hp: int, maxHp: int) -> string {
  let pct = maxHp > 0 ? hp * 100 / maxHp : 0
  match pct {
    | n when n <= 0  => "DEAD"
    | n when n <= 20 => "CRITICAL"
    | n when n <= 45 => "Wounded"
    | n when n <= 70 => "Hurt"
    | _              => "Healthy"
  }
}

// ── v0.4 @test declarations — verified pure rule functions ────────────────────
@test "level_title: mage lv1 = Apprentice"  { level_title("mage", 1)   === "Apprentice" }
@test "level_title: mage lv10 = Archmage"   { level_title("mage", 10)  === "Archmage" }
@test "level_title: knight lv7 = Champion"  { level_title("knight", 7) === "Champion" }
@test "level_title: ranger lv15 = Pathfinder" { level_title("ranger", 15) === "Pathfinder" }
@test "class_symbol: mage = [M]"            { class_symbol("mage")   === "[M]" }
@test "class_symbol: ranger = [R]"          { class_symbol("ranger") === "[R]" }
@test "combat_outcome: roll 20 = PERFECT"   { combat_outcome_label(20).includes("PERFECT") }
@test "combat_outcome: roll 5 = grazes"     { combat_outcome_label(5) === "grazes" }
@test "combat_outcome: roll 1 = misses"     { combat_outcome_label(1) === "misses" }
@test "hp_status_label: 0 = DEAD"           { hp_status_label(0, 100)  === "DEAD" }
@test "hp_status_label: 15 = CRITICAL"      { hp_status_label(15, 100) === "CRITICAL" }
@test "hp_status_label: 80 = Healthy"       { hp_status_label(80, 100) === "Healthy" }
@test "element_bonus: mage vs arcane = 9"   { element_bonus("mage", "arcane") === 9 }
@test "element_bonus: knight vs light = 4"  { element_bonus("knight", "light") === 4 }
@test "element_bonus: no match = 0"         { element_bonus("mage", "fire") === 7 }

// Nested match — core Synth feature: two axes in one expression
@intent "Elemental affinity bonus — heroClass column vs weakness row"
@pure @total
fn element_bonus :: (heroClass: string, weakness: string) -> int {
  match heroClass {
    | "mage"   => match weakness { | "arcane" => 9 | "fire" => 7 | "light" => 8 | _ => 0 }
    | "ranger" => match weakness { | "nature" => 7 | "cold" => 5 | "thunder" => 8 | _ => 0 }
    | "knight" => match weakness { | "physical" => 6 | "light" => 4 | _ => 0 }
    | _        => 0
  }
}

// Nested match for shop equip filtering
@pure @total
fn can_class_equip :: (heroClass: string, forClass: string) -> bool {
  match forClass {
    | "all"    => true
    | "mage"   => heroClass === "mage"
    | "knight" => heroClass === "knight"
    | "ranger" => heroClass === "ranger"
    | _        => false
  }
}

@pure @total
fn weakness_label :: (weakness: string) -> string {
  match weakness {
    | "arcane"   => "Weak to ARCANE   [mage +9]"
    | "fire"     => "Weak to FIRE     [mage +7, ranger +0]"
    | "light"    => "Weak to LIGHT    [mage +8, knight +4]"
    | "thunder"  => "Weak to THUNDER  [ranger +8]"
    | "nature"   => "Weak to NATURE   [ranger +7]"
    | "cold"     => "Weak to COLD     [ranger +5]"
    | "physical" => "Weak to PHYSICAL [knight +6]"
    | _          => "No known weakness"
  }
}

@pure @total
fn item_label :: (effect: string, power: int) -> string {
  match effect {
    | "heal"    => "Restore {power} HP (one hero)"
    | "healAll" => "Restore {power} HP (all heroes)"
    | "revive"  => "Revive fallen hero"
    | "damage"  => "Deal {power} damage"
    | _         => "—"
  }
}

// ══════════════════════════════════════════════════════════════════════════════
// GAME LOGIC — @pure functions
// ══════════════════════════════════════════════════════════════════════════════

@intent "Full hit breakdown — power, armor mitigation (def/2), crit multiplier, final"
@pure @total
fn damage_breakdown :: (atk: int, def: int, bonus: int, roll: int) -> any {
  let mitigation = Math.floor(def / 2)
  let power      = atk + bonus
  let afterArmor = Math.max(1, power - mitigation)
  let isCrit     = roll >= 18
  let mult       = isCrit ? 2 : 1
  let finalDmg   = Math.max(1, afterArmor * mult)
  { atk, bonus, power, mitigation, afterArmor, isCrit, finalDmg }
}

@intent "Memoized damage formula — same inputs always yield same result"
@pure @total @memo
fn compute_damage :: (atk: int, def: int, bonus: int, roll: int) -> int {
  damage_breakdown(atk, def, bonus, roll).finalDmg
}

@pure @total
fn armor_source :: (defender: any) -> string {
  defender.armor ? defender.armor.name : "defense"
}

@intent "Battle payout — 25% bonus so potion-heavy runs can still finish the weapon ladder"
@pure @total
fn battle_gold :: (baseReward: int) -> int {
  Math.floor(baseReward * 5 / 4)
}

@pure @total
fn apply_damage :: (entity: any, dmg: int) -> any {
  let newHp = Math.max(0, entity.hp - dmg)
  { ...entity, hp: newHp, alive: newHp > 0 }
}

@pure @total
fn apply_heal :: (hero: Hero, amount: int) -> Hero {
  let newHp = Math.min(hero.maxHp, hero.hp + amount)
  { ...hero, hp: newHp }
}

@pure @total
fn apply_revive :: (hero: Hero, hp: int) -> Hero {
  let revHp = Math.min(hero.maxHp, hp)
  { ...hero, hp: revHp, alive: true }
}

@intent "Increment level, increase stats, carry over excess XP"
@pure @total
fn apply_level_up :: (hero: Hero) -> Hero {
  let newLevel = hero.level + 1
  let hpGain   = 12
  let newMax   = hero.maxHp + hpGain
  {
    ...hero,
    level:        newLevel,
    xp:           hero.xp - xp_to_next(hero.level),
    maxHp:        newMax,
    hp:           Math.min(hero.hp + hpGain, newMax),
    baseStrength: hero.baseStrength + 1,
    baseDefense:  hero.baseDefense + 1
  }
}

@pure @total
fn maybe_level_up :: (hero: Hero) -> Hero {
  hero.xp >= xp_to_next(hero.level) && hero.level < 20
    ? apply_level_up(hero)
    : hero
}

@intent "Add XP and trigger level-up if threshold crossed; dead heroes unchanged"
@pure @total
fn award_xp :: (hero: Hero, xpGained: int) -> Hero {
  hero.alive ? maybe_level_up({ ...hero, xp: hero.xp + xpGained }) : hero
}

// ── Party pipelines using .field shorthand ────────────────────────────────────

fn alive_heroes(party) = party |> filter(.alive)
fn party_hp(party)     = party |> filter(.alive) |> map(.hp) |> sum
fn any_alive(party)    = party |> any(.alive)
fn hero_names(party)   = party |> filter(.alive) |> map(.name)

@intent "Heroes recover 50 HP resting in town; dead heroes stay dead"
@pure @total
fn rest_party :: (party: Hero[]) -> Hero[] {
  party |> map(h => h.alive ? { ...h, hp: Math.min(h.maxHp, h.hp + 50) } : h)
}

// ── Param-validation-injected constructor ─────────────────────────────────────

@intent "All 6 params auto-validated at entry; each with its own guard clause"
@pure @total
fn create_hero :: (name: HeroName, heroClass: ClassName, hp: HP, strength: StatValue, defense: StatValue, level: Level) -> Hero {
  { name, heroClass, hp, maxHp: hp, baseStrength: strength, baseDefense: defense, level, xp: 0, alive: true, weapon: null, armor: null }
}

