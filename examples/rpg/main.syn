// ══════════════════════════════════════════════════════════════════════════════
// DOM BUILDER HELPER
// ══════════════════════════════════════════════════════════════════════════════

@effects [dom.create, dom.attrs]
fn el :: (tag: string, attrs: object, ...children: any[]) -> Element {
  let e = document.createElement(tag)
  let _ = Object.entries(attrs).forEach(([k, v]) => {
    if (k === "class")    { e.className = v }
    else if (k === "id")       { e.id = v }
    else if (k === "disabled") { e.disabled = v }
    else if (k === "type")     { e.type = v }
    else { e.setAttribute(k, String(v)) }
  })
  let _ = children.flat().forEach(child => {
    if (typeof child === "string") { e.appendChild(document.createTextNode(child)) }
    else if (child instanceof Node) { e.appendChild(child) }
  })
  e
}

// ══════════════════════════════════════════════════════════════════════════════
// MAIN ENTRY — state machine + scene renderers
// ══════════════════════════════════════════════════════════════════════════════

@intent "Bootstrap the RPG — all scenes wired to a single mutable state"
@effects [dom.write, dom.events, state.mutable, rng]
fn render_game :: (rootId: string) -> void {

  let state = {
    scene:      "intro",
    introSlide: 0,
    party:      [
      create_hero("Aria",   "mage",   60, 11, 5,  1),
      create_hero("Theron", "knight", 80,  7, 11, 1),
      create_hero("Lyra",   "ranger", 70,  9,  7, 1)
    ],
    gold:       50,
    inventory:  starting_potions(),
    stash:      [],
    purchased:  [],
    pickingFor: null,
    itemTarget: null,
    stageNum:   0,
    enemy:      null,
    battleLog:  [],
    battleWon:  false
  }

  let root = document.getElementById(rootId)

  // ── Forward declaration — render dispatches to the current scene ────────────
  let render = () => {
    root.innerHTML = ""
    if (state.scene === "intro")    { render_intro() }
    if (state.scene === "title")    { render_title() }
    if (state.scene === "town")     { render_town() }
    if (state.scene === "shop")     { render_shop() }
    if (state.scene === "equip")    { render_equip() }
    if (state.scene === "battle")   { render_battle() }
    if (state.scene === "gameover") { render_gameover() }
    if (state.scene === "victory")  { render_victory() }
  }

  // ── Transition helpers ──────────────────────────────────────────────────────
  let go_town = () => {
    let rested = rest_party(state.party)
    state = { ...state, scene: "town", battleLog: [], battleWon: false, party: rested, pickingFor: null, itemTarget: null }
    render()
  }

  let go_battle = () => {
    let e = make_enemy(state.stageNum)
    let log = ["** {e.name} appears! **", weakness_label(e.weakness), ""]
    state = { ...state, scene: "battle", enemy: e, battleLog: log, battleWon: false, pickingFor: null, itemTarget: null }
    render()
  }

  let go = (scene) => {
    state = { ...state, scene: scene, pickingFor: null, itemTarget: null }
    render()
  }

  // ── Battle helpers ──────────────────────────────────────────────────────────

  let do_round = () => {
    let alive  = alive_heroes(state.party)
    let enemy  = state.enemy
    let log    = state.battleLog.slice()

    if (alive.length > 0 && enemy.alive) {
      // All living heroes attack in sequence
      let _ = alive.forEach(hero => {
        if (enemy.alive) {
          let roll    = Math.floor(Math.random() * 20) + 1
          let bonus   = element_bonus(hero.heroClass, enemy.weakness)
          let outcome = combat_outcome_label(roll)
          let means   = attack_means(hero)
          let missed  = outcome === "misses"
          let { atk, bonus: hitBonus, mitigation, isCrit, finalDmg } = damage_breakdown(effective_str(hero), enemy.defense, bonus, roll)
          let dmg     = missed ? 0 : finalDmg
          enemy = missed ? enemy : apply_damage(enemy, dmg)
          let _ = log.push(fmt_attack(hero.name, means, outcome, enemy.name, dmg))
          let _ = missed ? 0 : log.push(fmt_dmg_detail(atk, hitBonus, mitigation, "defense", isCrit, finalDmg))
        }
      })

      state = { ...state, enemy: enemy }

      if (!enemy.alive) {
        // Victory — award rewards, level up party
        let xpGain   = enemy.xpReward
        let goldGain = battle_gold(enemy.goldReward)
        let _ = log.push("")
        let _ = log.push("** {enemy.name} defeated! **")
        let _ = log.push("Gained {xpGain} XP and {goldGain} gold.")
        let oldParty = state.party
        let newParty = state.party |> map(h => award_xp(h, xpGain))
        let _ = newParty.forEach(h => {
          let old = oldParty.find(p => p.name === h.name)
          if (old && h.level > old.level) {
            let _ = log.push(fmt_level_up(h.name, h.level))
          }
        })
        let newStage = state.stageNum + 1
        state = {
          ...state,
          party:     newParty,
          gold:      state.gold + goldGain,
          stageNum:  newStage,
          battleWon: true,
          battleLog: log
        }
        render()
      } else {
        // Enemy counterattacks a random living hero
        let ti         = Math.floor(Math.random() * alive.length)
        let target     = alive[ti]
        let { atk: eAtk, bonus: eBonus, mitigation: eMit, isCrit: eCrit, finalDmg: eDmg } = damage_breakdown(enemy.attack, effective_def(target), 0, 10)
        let eArmor     = armor_source(target)
        let targetDies = target.hp - eDmg <= 0
        let newParty   = state.party |> map(h => h.name === target.name ? apply_damage(h, eDmg) : h)
        let _ = log.push(fmt_attack(enemy.name, "claws", "strikes back at", target.name, eDmg))
        let _ = log.push(fmt_dmg_detail(eAtk, eBonus, eMit, eArmor, eCrit, eDmg))
        let _ = targetDies ? log.push(fmt_death(target.name)) : 0
        state = { ...state, party: newParty, battleLog: log }
        if (!any_alive(state.party)) {
          let _ = log.push("")
          let _ = log.push("** Your entire party has fallen... **")
          state = { ...state, battleLog: log }
          render()
        } else {
          state = { ...state, battleLog: log }
          render()
        }
      }
    }
  }

  let item_needs_target = (item) => item.effect === "heal" || item.effect === "revive"

  let can_target_with = (item, hero) => {
    item.effect === "heal"
      ? hero.alive && hero.hp < hero.maxHp
      : item.effect === "revive"
        ? !hero.alive
        : false
  }

  let item_targets = (item) => state.party.filter(h => can_target_with(item, h))

  let can_use_item = (item) => {
    item.effect === "damage"
      ? state.scene === "battle" && state.enemy && state.enemy.alive
      : item.effect === "healAll"
        ? alive_heroes(state.party).length > 0
        : item_targets(item).length > 0
  }

  let begin_use_item = (item) => {
    if (can_use_item(item)) {
      if (item_needs_target(item)) {
        state = { ...state, itemTarget: item }
        render()
      } else {
        use_item(item, null)
      }
    }
  }

  let cancel_item_target = () => {
    state = { ...state, itemTarget: null }
    render()
  }

  let use_item = (item, hero) => {
    let validTarget = item_needs_target(item)
      ? hero !== null && hero !== undefined && can_target_with(item, hero)
      : true
    if (can_use_item(item) && validTarget) {
      let inBattle = state.scene === "battle"
      let log      = inBattle ? state.battleLog.slice() : []
      let newInv   = state.inventory
        .map(i => i.id === item.id ? { ...i, count: i.count - 1 } : i)
        .filter(i => i.count > 0)

      if (item.effect === "heal") {
        let newParty = state.party |> map(h => h.name === hero.name ? apply_heal(h, item.power) : h)
        let _ = log.push(fmt_heal(hero.name, item.name, item.power))
        state = { ...state, party: newParty, inventory: newInv, battleLog: log, itemTarget: null }
        render()
      } else if (item.effect === "healAll") {
        let newParty = state.party |> map(h => h.alive ? apply_heal(h, item.power) : h)
        let _ = log.push("  {item.name} — all heroes restored {item.power} HP.")
        state = { ...state, party: newParty, inventory: newInv, battleLog: log, itemTarget: null }
        render()
      } else if (item.effect === "revive") {
        let newParty = state.party |> map(h => h.name === hero.name ? apply_revive(h, item.power) : h)
        let _ = log.push(fmt_revive(hero.name, item.name))
        state = { ...state, party: newParty, inventory: newInv, battleLog: log, itemTarget: null }
        render()
      } else if (item.effect === "damage") {
        let newHp    = Math.max(0, state.enemy.hp - item.power)
        let newEnemy = { ...state.enemy, hp: newHp, alive: newHp > 0 }
        let _ = log.push("  {item.name} — {item.power} damage to {state.enemy.name}!")
        if (!newEnemy.alive) {
          let _ = log.push("** {state.enemy.name} defeated! **")
          let xpGain   = state.enemy.xpReward
          let goldGain = battle_gold(state.enemy.goldReward)
          let _ = log.push("Gained {xpGain} XP and {goldGain} gold.")
          let oldParty = state.party
          let newParty = state.party |> map(h => award_xp(h, xpGain))
          let _ = newParty.forEach(h => {
            let old = oldParty.find(p => p.name === h.name)
            if (old && h.level > old.level) {
              let _ = log.push(fmt_level_up(h.name, h.level))
            }
          })
          let newStage = state.stageNum + 1
          state = { ...state, enemy: newEnemy, party: newParty, gold: state.gold + goldGain, stageNum: newStage, battleWon: true, inventory: newInv, battleLog: log, itemTarget: null }
          render()
        } else {
          state = { ...state, enemy: newEnemy, inventory: newInv, battleLog: log, itemTarget: null }
          render()
        }
      }
    }
  }

  // Shared target picker for potions that need a hero
  let render_item_target_picker = () => {
    let item = state.itemTarget
    let panel = el("div", { class: "item-target-panel" })
    let _ = panel.appendChild(
      el("div", { class: "picker-label" }, "Use {item.name} on whom?")
    )
    let targets = item_targets(item)
    let _ = targets.forEach(hero => {
      let face   = hero_art_mini(hero.name)
      let status = hero.alive
        ? "{hero.hp}/{hero.maxHp} HP"
        : "fallen"
      let tBtn = el("button", { class: "btn-target-hero" },
        el("span", { class: "hero-face" }, face),
        el("span", { class: "target-name" }, hero.name),
        el("span", { class: "target-status dim" }, status)
      )
      let _ = tBtn.addEventListener("click", () => { use_item(item, hero) })
      let _ = panel.appendChild(tBtn)
    })
    let cancelBtn = el("button", { class: "btn-secondary" }, "CANCEL")
    let _ = cancelBtn.addEventListener("click", cancel_item_target)
    let _ = panel.appendChild(el("div", { class: "btn-row" }, cancelBtn))
    panel
  }

  // ── Equipment management helpers ───────────────────────────────────────────

  let equip_item = (hero, newEquip) => {
    let slot     = newEquip.slot
    let oldEquip = slot === "weapon" ? hero.weapon : hero.armor
    let idx      = state.stash.findIndex(e => e.id === newEquip.id)
    let trimmed  = state.stash.filter((e, i) => i !== idx)
    let newStash = oldEquip ? trimmed.concat([oldEquip]) : trimmed
    let newParty = state.party.map(h => {
      if (h.name === hero.name) {
        let patched = slot === "weapon"
          ? { ...h, weapon: newEquip }
          : { ...h, armor: newEquip }
        patched
      } else {
        h
      }
    })
    state = { ...state, party: newParty, stash: newStash, pickingFor: null }
    render()
  }

  let unequip_item = (hero, slot) => {
    let equip = slot === "weapon" ? hero.weapon : hero.armor
    if (equip) {
      let patched  = slot === "weapon" ? { ...hero, weapon: null } : { ...hero, armor: null }
      let newParty = state.party.map(h => h.name === hero.name ? patched : h)
      state = { ...state, party: newParty, stash: state.stash.concat([equip]) }
      render()
    }
  }

  // ══════════════════════════════════════════════════════════════════════════
  // SCENE: EQUIPMENT ROSTER
  // ══════════════════════════════════════════════════════════════════════════

  let render_equip = () => {
    let stashCount = state.stash.length
    let stashWord  = stashCount === 1 ? "item" : "items"
    let header = el("div", { class: "scene-header" },
      el("span", { class: "scene-title" }, "EQUIPMENT"),
      el("span", { class: "gold-display" }, "Stash: {stashCount} {stashWord}")
    )
    let _ = root.appendChild(header)

    // ── Per-hero equip cards in a 3-col grid ──────────────────────────────
    let heroGrid = el("div", { class: "equip-hero-grid" })
    let _ = state.party.forEach(hero => {
      let artLines = hero_art(hero.name)
      let artPre   = document.createElement("pre")
      artPre.className = hero.alive ? "hero-portrait" : "hero-portrait portrait-dead"
      artPre.textContent = artLines.join("\n")

      // Weapon slot
      let wIcon    = hero.weapon?.id ? equip_icon(hero.weapon.id) : "   "
      let wName    = hero.weapon?.name ?? "(none)"
      let wDesc    = hero.weapon?.desc ?? ""
      let wChgBtn  = el("button", { class: "btn-slot" }, "CHANGE")
      let wRemBtn  = el("button", { class: "btn-unequip", disabled: !hero.weapon }, "REMOVE")
      let _ = wChgBtn.addEventListener("click", () => {
        state = { ...state, pickingFor: { heroName: hero.name, slot: "weapon" } }
        render()
      })
      if (hero.weapon) {
        let _ = wRemBtn.addEventListener("click", () => { unequip_item(hero, "weapon") })
      }
      let wSlot = el("div", { class: "equip-slot" },
        el("div", { class: "slot-label" }, "WEAPON"),
        el("div", { class: "slot-item" },
          el("span", { class: "item-icon" }, wIcon),
          el("span", {}, wName),
          el("span", { class: "slot-desc" }, wDesc)
        ),
        el("div", { class: "slot-btns" }, wChgBtn, wRemBtn)
      )

      // Armor slot
      let aIcon    = hero.armor?.id ? equip_icon(hero.armor.id) : "   "
      let aName    = hero.armor?.name ?? "(none)"
      let aDesc    = hero.armor?.desc ?? ""
      let aChgBtn  = el("button", { class: "btn-slot" }, "CHANGE")
      let aRemBtn  = el("button", { class: "btn-unequip", disabled: !hero.armor }, "REMOVE")
      let _ = aChgBtn.addEventListener("click", () => {
        state = { ...state, pickingFor: { heroName: hero.name, slot: "armor" } }
        render()
      })
      if (hero.armor) {
        let _ = aRemBtn.addEventListener("click", () => { unequip_item(hero, "armor") })
      }
      let aSlot = el("div", { class: "equip-slot" },
        el("div", { class: "slot-label" }, "ARMOR"),
        el("div", { class: "slot-item" },
          el("span", { class: "item-icon" }, aIcon),
          el("span", {}, aName),
          el("span", { class: "slot-desc" }, aDesc)
        ),
        el("div", { class: "slot-btns" }, aChgBtn, aRemBtn)
      )

      // Effective stats
      let atkTotal = effective_str(hero)
      let defTotal = effective_def(hero)
      let statsStr = "ATK {atkTotal}  DEF {defTotal}"

      let card = el("div", { class: "equip-hero-card" },
        artPre,
        el("div", { class: "portrait-name" }, hero.name),
        el("div", { class: "portrait-class" }, class_symbol(hero.heroClass)),
        el("div", { class: "equip-hero-stats dim" }, statsStr),
        wSlot,
        aSlot
      )
      let _ = heroGrid.appendChild(card)
    })
    let _ = root.appendChild(heroGrid)

    // ── Picker dialog — floats above layout when CHANGE is clicked ───────
    let dialog    = document.getElementById("picker-dialog")
    let dialogInner = document.getElementById("picker-panel-inner")
    let backdrop  = document.getElementById("picker-backdrop")
    let closePicker = () => {
      state = { ...state, pickingFor: null }
      dialog.classList.add("hidden")
      dialogInner.innerHTML = ""
      render()
    }
    if (state.pickingFor) {
      let pf   = state.pickingFor
      let hero = state.party.find(h => h.name === pf.heroName)
      let compat = state.stash.filter(e =>
        e.slot === pf.slot && can_class_equip(hero.heroClass, e.forClass)
      )
      dialogInner.innerHTML = ""
      let dialogHeader = el("div", { class: "picker-dialog-header" },
        el("div", { class: "picker-label" }, "Choose {pf.slot} for {pf.heroName}"),
        el("button", { class: "picker-close" }, "✕")
      )
      let _ = dialogHeader.querySelector(".picker-close").addEventListener("click", closePicker)
      let _ = backdrop.addEventListener("click", closePicker)
      let _ = dialogInner.appendChild(dialogHeader)
      if (compat.length === 0) {
        let _ = dialogInner.appendChild(
          el("div", { class: "dim" }, "No compatible {pf.slot}s in stash. Visit the merchant.")
        )
      } else {
        let _ = compat.forEach(equip => {
          let icon    = equip_icon(equip.id)
          let pickBtn = el("button", { class: "btn-pick" },
            el("span", { class: "item-icon" }, icon),
            el("span", {}, equip.name),
            el("span", { class: "pick-stat" }, equip.desc)
          )
          let _ = pickBtn.addEventListener("click", () => { equip_item(hero, equip) })
          let _ = dialogInner.appendChild(pickBtn)
        })
      }
      dialog.classList.remove("hidden")
    } else {
      let _ = dialog.classList.add("hidden")
      // ── Stash panel — all unequipped gear ──────────────────────────────
      let stashPanel = el("div", { class: "stash-panel" })
      let _ = stashPanel.appendChild(el("div", { class: "panel-label" }, "STASH — UNEQUIPPED GEAR"))
      if (state.stash.length === 0) {
        let _ = stashPanel.appendChild(
          el("div", { class: "dim" }, "Stash is empty. Buy gear from the merchant then equip it here.")
        )
      } else {
        let _ = state.stash.forEach(equip => {
          let icon = equip_icon(equip.id)
          let who  = equip.forClass === "all" ? "any class" : equip.forClass
          let _ = stashPanel.appendChild(el("div", { class: "stash-item" },
            el("span", { class: "item-icon" }, icon),
            el("span", { class: "item-name" }, equip.name),
            el("span", { class: "item-stats" }, equip.desc),
            el("span", { class: "item-for" }, who)
          ))
        })
      }
      let _ = root.appendChild(stashPanel)
    }

    let backBtn = el("button", { class: "btn-secondary" }, "BACK TO INN")
    let _ = backBtn.addEventListener("click", () => { go("town") })
    let _ = root.appendChild(el("div", { class: "btn-row" }, backBtn))
  }

  // ══════════════════════════════════════════════════════════════════════════
  // SCENE: INTRO — three-slide comedic cold open
  // ══════════════════════════════════════════════════════════════════════════

  let render_intro = () => {
    let slide = state.introSlide

    let s0 = {
      title: "A LAND IN PERIL",
      text: """
In the realm of ALDENMOOR, a great evil has awakened.

Crops wilt.  Rivers run backwards.
A cow in the village of Fenwick produced no milk for a week.
The cow was later found to be fine.  She was just having a moment.

The ANCIENT LICH, known as MALVRAK THE UNDYING,
has sealed himself inside a dungeon and dispatched
an army of monsters to terrorize the land.

Eyewitnesses describe the monsters as:
  - quite unpleasant
  - surprisingly chatty before attacking
  - smelled strongly of brimstone

Something must be done.
Tavern prices alone have risen 40% since the siege began."""
    }

    let s1 = {
      title: "THE CALL TO ARMS",
      text: """
A notice was posted on the town board at first light.

   +------------------------------------------+
   |                                          |
   |  HEROES WANTED — URGENT                  |
   |                                          |
   |  Must be willing to enter a dungeon.     |
   |  Dungeon is large.  Monsters numerous.   |
   |  Ancient Lich described as immortal.     |
   |                                          |
   |  Compensation: gold, glory, and our      |
   |  sincere and heartfelt gratitude.        |
   |  (Mostly gratitude.  Some gold.)         |
   |                                          |
   +------------------------------------------+

By midday, three heroes had replied.

The town council described this as  acceptable
and  considerably better than the zero we expected."""
    }

    let s2 = {
      title: "YOUR BRAVE PARTY",
      text: """
ARIA  — Mage.  Studied at the Academy for nine years.
         Specializes in arcane destruction.
         Once accidentally turned a cow into a hat.
         Has not yet lived this down.  The cow was fine.

THERON — Knight.  Valiant.  Honorable.  Extremely tall.
         Carries a shield, a sword, and the party frying pan.
         Considers the frying pan a secondary weapon.
         (Statistically, he has been right about this.)

LYRA  — Ranger.  Can speak to animals.
         The animals mostly complain about the weather.
         She passes along the parts that seem tactically useful.
         They have been mostly wrong.

Together they have 50 gold and immense self-belief.
The lich has centuries of evil, an army, and a dungeon.
50 battles. 5 chapters. 4 tiers of gear. 1 ancient evil.

We are rooting for the party.
Statistically, it could go either way."""
    }

    let slides   = [s0, s1, s2]
    let current  = slides[slide]
    let isLast   = slide >= slides.length - 1
    let slideNum = slide + 1
    let total    = slides.length

    let _ = root.appendChild(
      el("div", { class: "intro-eyebrow" }, "~ THE CHRONICLES OF ALDENMOOR ~")
    )

    let titleEl = el("div", { class: "intro-slide-title" }, current.title)
    let _ = root.appendChild(titleEl)

    let textBox = el("div", { class: "intro-text-box" })
    let _ = current.text.split("\n").forEach(line => {
      let cls = line === "" ? "intro-spacer" : "intro-line"
      let _ = textBox.appendChild(el("div", { class: cls }, line))
    })
    let _ = root.appendChild(textBox)

    let _ = root.appendChild(
      el("div", { class: "intro-pager dim" }, "— {slideNum} of {total} —")
    )

    let btnLabel = isLast ? "BEGIN ADVENTURE" : "NEXT  >"
    let btnCls   = isLast ? "btn-primary" : "btn-intro-next"
    let advBtn   = el("button", { class: btnCls }, btnLabel)
    let _ = advBtn.addEventListener("click", () => {
      if (isLast) {
        go("title")
      } else {
        state = { ...state, introSlide: state.introSlide + 1 }
        render()
      }
    })

    let skipBtn = el("button", { class: "btn-intro-skip" }, "skip intro")
    let _ = skipBtn.addEventListener("click", () => { go("title") })

    let _ = root.appendChild(el("div", { class: "intro-btn-row" }, advBtn, skipBtn))
  }

  // ══════════════════════════════════════════════════════════════════════════
  // SCENE: TITLE
  // ══════════════════════════════════════════════════════════════════════════

  let render_title = () => {
    let logo = """
+=========================================+
|                                         |
|    A  X  O  N      R  P  G              |
|                                         |
|  An AI-native language demo             |
|  50 battles. 5 chapters. 1 Ancient Lich.|
|  Buy gear. Level up. Survive.           |
|                                         |
+=========================================+"""
    let pre = document.createElement("pre")
    pre.className = "ascii-logo"
    pre.textContent = logo
    let _ = root.appendChild(pre)

    // Character roster preview
    let rosterRow = el("div", { class: "portrait-row" })
    let _ = state.party.forEach(hero => {
      let artLines = hero_art(hero.name)
      let artPre   = document.createElement("pre")
      artPre.className = "hero-portrait"
      artPre.textContent = artLines.join("\n")
      let card = el("div", { class: "portrait-card" },
        artPre,
        el("div", { class: "portrait-name" }, hero.name),
        el("div", { class: "portrait-class" }, class_symbol(hero.heroClass)),
        el("div", { class: "portrait-class" }, "{hero.heroClass}  Lv.{hero.level}")
      )
      let _ = rosterRow.appendChild(card)
    })
    let _ = root.appendChild(rosterRow)

    let info = el("div", { class: "title-info" },
      el("div", { class: "dim" }, "Three heroes  ·  50 battles  ·  5 chapters  ·  4 tiers of gear"),
      el("div", { class: "dim" }, "All game logic written in Synth v1.0, transpiled to JavaScript.")
    )
    let _ = root.appendChild(info)

    let startBtn = el("button", { class: "btn-primary" }, "BEGIN ADVENTURE")
    let _ = startBtn.addEventListener("click", () => { go("town") })
    let _ = root.appendChild(el("div", { class: "btn-row" }, startBtn))
  }

  // ══════════════════════════════════════════════════════════════════════════
  // SCENE: TOWN
  // ══════════════════════════════════════════════════════════════════════════

  let render_town = () => {
    let stageName  = stage_name(state.stageNum)
    let stagesLeft = 50 - state.stageNum

    let header = el("div", { class: "scene-header" },
      el("span", { class: "scene-title" }, "THE INN"),
      el("span", { class: "gold-display" }, "Gold: {state.gold}")
    )
    let _ = root.appendChild(header)

    let stageInfo = state.stageNum < 50
      ? "Next: {stageName}"
      : "All fifty stages complete!"
    let _ = root.appendChild(el("div", { class: "stage-info" }, stageInfo))

    // Portrait gallery
    let portraitRow = el("div", { class: "portrait-row" })
    let _ = state.party.forEach(hero => {
      let artLines = hero_art(hero.name)
      let artPre   = document.createElement("pre")
      artPre.className = hero.alive ? "hero-portrait" : "hero-portrait portrait-dead"
      artPre.textContent = artLines.join("\n")
      let hpStr    = "{hero.hp}/{hero.maxHp} HP"
      let cardCls  = hero.alive ? "portrait-card" : "portrait-card portrait-dead"
      let card     = el("div", { class: cardCls },
        artPre,
        el("div", { class: "portrait-name" }, hero.name),
        el("div", { class: "portrait-class" }, class_symbol(hero.heroClass)),
        el("div", { class: "portrait-hp" }, hpStr)
      )
      let _ = portraitRow.appendChild(card)
    })
    let _ = root.appendChild(portraitRow)

    // Party stats panel
    let partyPanel = el("div", { class: "party-panel" })
    let _ = state.party.forEach(hero => {
      let rowClass  = hero.alive ? "hero-row" : "hero-row hero-dead"
      let equipStr  = format_equip_with_icons(hero)
      let row = el("div", { class: rowClass },
        el("div", {}, format_hero_line(hero)),
        el("div", { class: "dim" }, format_xp_line(hero)),
        el("div", { class: "equip-line" }, equipStr)
      )
      let _ = partyPanel.appendChild(row)
    })
    let totalHp    = party_hp(state.party)
    let aliveCount = alive_heroes(state.party).length
    let _ = partyPanel.appendChild(el("div", { class: "party-summary" }, "Party: {aliveCount}/3 alive · {totalHp} HP total"))
    let _ = root.appendChild(partyPanel)

    // Potion / item inventory — usable at the inn
    let invPanel = el("div", { class: "inv-panel" })
    let _ = invPanel.appendChild(el("div", { class: "panel-label" }, "ITEMS"))
    if (state.inventory.length === 0) {
      let _ = invPanel.appendChild(el("div", { class: "dim" }, "No potions or items. Visit the merchant."))
    } else {
      let _ = state.inventory.forEach(item => {
        let icon   = equip_icon(item.id)
        let canUse = can_use_item(item)
        let useBtn = el("button", { class: "btn-use-item", disabled: !canUse }, "USE")
        let _ = useBtn.addEventListener("click", () => { begin_use_item(item) })
        let row = el("div", { class: "inv-item-row" },
          el("span", { class: "item-icon" }, icon),
          el("span", { class: "inv-item-name" }, "{item.name} x{item.count}"),
          el("span", { class: "inv-item-desc dim" }, item.desc),
          useBtn
        )
        let _ = invPanel.appendChild(row)
      })
    }
    let _ = root.appendChild(invPanel)

    if (state.itemTarget) {
      let _ = root.appendChild(render_item_target_picker())
    }

    // Stash summary
    if (state.stash.length > 0) {
      let stashSummary = el("div", { class: "inv-panel" })
      let _ = stashSummary.appendChild(el("div", { class: "panel-label" }, "GEAR STASH"))
      let _ = state.stash.forEach(equip => {
        let icon = equip_icon(equip.id)
        let _ = stashSummary.appendChild(el("div", { class: "inv-item stash-inv-item" }, "{icon}{equip.name}  {equip.desc}"))
      })
      let _ = stashSummary.appendChild(
        el("div", { class: "dim stash-hint" }, "Use EQUIPMENT to assign gear to heroes.")
      )
      let _ = root.appendChild(stashSummary)
    }

    // Action buttons
    let btnRow = el("div", { class: "btn-row" })
    let shopBtn  = el("button", { class: "btn-secondary" }, "SHOP")
    let equipBtn = el("button", { class: "btn-secondary" }, "EQUIPMENT")
    let _ = shopBtn.addEventListener("click",  () => { go("shop") })
    let _ = equipBtn.addEventListener("click", () => { go("equip") })
    let _ = btnRow.appendChild(shopBtn)
    let _ = btnRow.appendChild(equipBtn)

    if (state.stageNum < 50) {
      let ventureBtn = el("button", { class: "btn-primary" }, "VENTURE FORTH")
      let _ = ventureBtn.addEventListener("click", go_battle)
      let _ = btnRow.appendChild(ventureBtn)
    }
    let _ = root.appendChild(btnRow)

    let restNote = el("div", { class: "rest-note dim" }, "(Heroes recovered 25 HP resting here.)")
    let _ = root.appendChild(restNote)
  }

  // ══════════════════════════════════════════════════════════════════════════
  // SCENE: SHOP
  // ══════════════════════════════════════════════════════════════════════════

  let render_shop = () => {
    let leave_shop = () => { go("town") }

    let leaveTop = el("button", { class: "btn-secondary" }, "LEAVE SHOP")
    let _ = leaveTop.addEventListener("click", leave_shop)
    let header = el("div", { class: "scene-header shop-header" },
      el("span", { class: "scene-title" }, "MERCHANT"),
      el("div", { class: "header-actions" },
        el("span", { class: "gold-display" }, "Gold: {state.gold}"),
        leaveTop
      )
    )
    let _ = root.appendChild(header)

    let buy_equip = (equip) => {
      let alreadySold = state.purchased.find(id => id === equip.id) !== undefined
      if (!alreadySold && state.gold >= equip.price) {
        state = {
          ...state,
          gold: state.gold - equip.price,
          stash: state.stash.concat([equip]),
          purchased: state.purchased.concat([equip.id])
        }
        render()
      }
    }

    let buy_item = (item) => {
      if (state.gold >= item.price) {
        let existing = state.inventory.find(i => i.id === item.id)
        let newInv = existing
          ? state.inventory.map(i => i.id === item.id ? { ...i, count: i.count + 1 } : i)
          : state.inventory.concat([{ ...item, count: 1 }])
        state = { ...state, gold: state.gold - item.price, inventory: newInv }
        render()
      }
    }

    let render_equip_section = (label, items) => {
      let section = el("div", { class: "shop-section" })
      let _ = section.appendChild(el("div", { class: "shop-label" }, label))
      let _ = items.forEach(equip => {
        let sold    = state.purchased.find(id => id === equip.id) !== undefined
        let canBuy  = !sold && state.gold >= equip.price
        let forWhom = equip.forClass === "all" ? "any class" : equip.forClass
        let btnLabel = sold ? "SOLD" : "BUY {equip.price}g"
        let btnCls   = sold ? "btn-buy btn-sold" : "btn-buy"
        let buyBtn   = el("button", { class: btnCls, disabled: !canBuy }, btnLabel)
        if (!sold) {
          let _ = buyBtn.addEventListener("click", () => { buy_equip(equip) })
        }
        let icon = equip_icon(equip.id)
        let rowCls = sold ? "shop-row shop-row-sold" : "shop-row"
        let row = el("div", { class: rowCls },
          el("span", { class: "item-icon" },  icon),
          el("span", { class: "item-name" },  equip.name),
          el("span", { class: "item-stats" }, equip.desc),
          el("span", { class: "item-for" },   forWhom),
          buyBtn
        )
        let _ = section.appendChild(row)
      })
      section
    }

    let render_item_section = (label, items) => {
      let section = el("div", { class: "shop-section" })
      let _ = section.appendChild(el("div", { class: "shop-label" }, label))
      let _ = items.forEach(item => {
        let canBuy = state.gold >= item.price
        let buyBtn = el("button", { class: "btn-buy", disabled: !canBuy }, "BUY {item.price}g")
        let _ = buyBtn.addEventListener("click", () => { buy_item(item) })
        let icon = equip_icon(item.id)
        let row = el("div", { class: "shop-row" },
          el("span", { class: "item-icon" },  icon),
          el("span", { class: "item-name" },  item.name),
          el("span", { class: "item-stats" }, item.desc),
          buyBtn
        )
        let _ = section.appendChild(row)
      })
      section
    }

    // Potions first so they are not buried under the gear catalog
    let _ = root.appendChild(render_item_section("POTIONS", shop_potions()))
    let _ = root.appendChild(render_item_section("BATTLE ITEMS", shop_battle_items()))
    let _ = root.appendChild(render_equip_section("WEAPONS", shop_weapons()))
    let _ = root.appendChild(render_equip_section("ARMOR",   shop_armors()))

    let leaveBot = el("button", { class: "btn-secondary" }, "LEAVE SHOP")
    let _ = leaveBot.addEventListener("click", leave_shop)
    let _ = root.appendChild(el("div", { class: "btn-row" }, leaveBot))
  }

  // ══════════════════════════════════════════════════════════════════════════
  // SCENE: BATTLE
  // ══════════════════════════════════════════════════════════════════════════

  let render_battle = () => {
    let enemy = state.enemy
    let alive = any_alive(state.party)
    let over  = !enemy.alive || !alive

    // Enemy panel
    let artLines = enemy_art(enemy.id)
    let artPre   = document.createElement("pre")
    artPre.className = "enemy-art"
    artPre.textContent = artLines.join("\n")

    let eBar  = hp_bar(enemy.hp, enemy.maxHp)
    let eInfo = el("div", { class: "enemy-info" },
      el("div", { class: "enemy-name" }, enemy.name),
      el("div", { class: "enemy-hp" },   "[{eBar}] {enemy.hp}/{enemy.maxHp} HP"),
      el("div", { class: "enemy-hint" }, weakness_label(enemy.weakness))
    )

    let enemyPanel = el("div", { class: "enemy-panel" }, artPre, eInfo)
    let _ = root.appendChild(enemyPanel)

    // Party panel
    let partyPanel = el("div", { class: "party-panel" })
    let _ = state.party.forEach(hero => {
      let face = hero_art_mini(hero.name)
      let rc   = hero.alive ? "hero-row hero-row-battle" : "hero-row hero-row-battle hero-dead"
      let row  = el("div", { class: rc },
        el("span", { class: "hero-face" }, face),
        el("span", {}, format_hero_line(hero))
      )
      let _ = partyPanel.appendChild(row)
    })
    let _ = root.appendChild(partyPanel)

    // Combat log — always pin to latest entry
    let logEl = el("div", { class: "combat-log" })
    let _ = state.battleLog.forEach(msg => {
      let _ = logEl.appendChild(el("div", { class: "log-line" }, msg))
    })
    let _ = root.appendChild(logEl)
    logEl.scrollTop = logEl.scrollHeight

    // Action buttons / item target picker
    if (state.itemTarget) {
      let _ = root.appendChild(render_item_target_picker())
    } else {
      let btnRow = el("div", { class: "btn-row" })

      if (!over) {
        let attackBtn = el("button", { class: "btn-attack" }, "ATTACK")
        let _ = attackBtn.addEventListener("click", do_round)
        let _ = btnRow.appendChild(attackBtn)

        let _ = state.inventory.forEach(item => {
          let canUse = can_use_item(item)
          let iBtn = el("button", { class: "btn-item", disabled: !canUse }, "USE {item.name}")
          let _ = iBtn.addEventListener("click", () => { begin_use_item(item) })
          let _ = btnRow.appendChild(iBtn)
        })
      } else if (!alive) {
        let gameOverBtn = el("button", { class: "btn-danger" }, "GAME OVER")
        let _ = gameOverBtn.addEventListener("click", () => { go("gameover") })
        let _ = btnRow.appendChild(gameOverBtn)
      } else {
        let contScene = state.stageNum >= 50 ? "victory" : "town"
        let contLabel = state.stageNum >= 50 ? "CLAIM VICTORY" : "RETURN TO INN"
        let contBtn = el("button", { class: "btn-primary" }, contLabel)
        let _ = contBtn.addEventListener("click", () => {
          if (contScene === "victory") { go("victory") } else { go_town() }
        })
        let _ = btnRow.appendChild(contBtn)
      }
      let _ = root.appendChild(btnRow)
    }
  }

  // ══════════════════════════════════════════════════════════════════════════
  // SCENE: GAME OVER
  // ══════════════════════════════════════════════════════════════════════════

  let render_gameover = () => {
    let skull = """
     _____     
    /     \    
   | () () |   
    \  ^  /    
     |||||     
     |||||     """
    let pre = document.createElement("pre")
    pre.className = "ascii-logo death"
    pre.textContent = skull
    let _ = root.appendChild(pre)
    let _ = root.appendChild(el("div", { class: "scene-msg death" }, "ALL HEROES HAVE FALLEN"))
    let _ = root.appendChild(el("div", { class: "dim" }, "The dungeon claims another adventure."))
    let restartBtn = el("button", { class: "btn-danger" }, "TRY AGAIN")
    let _ = restartBtn.addEventListener("click", () => {
      state = {
        scene:      "title",
        party:      [
          create_hero("Aria",   "mage",   60, 11, 5,  1),
          create_hero("Theron", "knight", 80,  7, 11, 1),
          create_hero("Lyra",   "ranger", 70,  9,  7, 1)
        ],
        gold:       50,
        inventory:  starting_potions(),
        stash:      [],
        purchased:  [],
        pickingFor: null,
        itemTarget: null,
        stageNum:   0,
        enemy:      null,
        battleLog:  [],
        battleWon:  false
      }
      render()
    })
    let _ = root.appendChild(el("div", { class: "btn-row" }, restartBtn))
  }

  // ══════════════════════════════════════════════════════════════════════════
  // SCENE: VICTORY
  // ══════════════════════════════════════════════════════════════════════════

  let render_victory = () => {
    let banner = """
+========================================+
|                                        |
|   V  I  C  T  O  R  Y  !               |
|                                        |
|   The Ancient Lich has been slain.     |
|   The dungeon is free.                 |
|                                        |
+========================================+"""
    let pre = document.createElement("pre")
    pre.className = "ascii-logo victory"
    pre.textContent = banner
    let _ = root.appendChild(pre)

    let statsPanel = el("div", { class: "party-panel" })
    let _ = statsPanel.appendChild(el("div", { class: "panel-label" }, "SURVIVORS"))
    let _ = state.party.forEach(hero => {
      if (hero.alive) {
        let rc = "hero-row"
        let _ = statsPanel.appendChild(el("div", { class: rc }, format_hero_line(hero)))
      }
    })
    let _ = statsPanel.appendChild(el("div", { class: "gold-display" }, "Final Gold: {state.gold}"))
    let _ = root.appendChild(statsPanel)

    let againBtn = el("button", { class: "btn-primary" }, "PLAY AGAIN")
    let _ = againBtn.addEventListener("click", () => {
      state = {
        scene:      "title",
        party:      [
          create_hero("Aria",   "mage",   60, 11, 5,  1),
          create_hero("Theron", "knight", 80,  7, 11, 1),
          create_hero("Lyra",   "ranger", 70,  9,  7, 1)
        ],
        gold:       50,
        inventory:  starting_potions(),
        stash:      [],
        purchased:  [],
        pickingFor: null,
        itemTarget: null,
        stageNum:   0,
        enemy:      null,
        battleLog:  [],
        battleWon:  false
      }
      render()
    })
    let _ = root.appendChild(el("div", { class: "btn-row" }, againBtn))
  }

  // ── Start ───────────────────────────────────────────────────────────────────
  render()
}
