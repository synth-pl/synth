@intent "Look up enemy for this stage from the memoized roster"
@pure @total
fn make_enemy :: (stageNum: int) -> any {
  all_enemies()[stageNum]
}

@intent "ASCII portrait — unique art for bosses and notable enemies, fallback for rest"
@pure @total
fn enemy_art :: (id: string) -> string[] {
  match id {
    // Chapter bosses
    | "warlord"     => ["   /[=]\\   ", "  (>.<)    ", "  /| |\\   ", "  |___|   ", "  // \\\\   "]
    | "crypt_lord"  => ["  .oOo.  ", " (X   X) ", "  [|o|]  ", "   |||   ", "   |||   "]
    | "stone_col"   => ["  #####  ", "  #O O#  ", "  #-_-#  ", "  #####  ", "  # # #  "]
    | "archdemon"   => ["  /\\**/\\  ", " (>|  |<)", "  |||||  ", "  \\|  |/ ", "   ||||  "]
    | "ancient_lich"=> ["    _____   ", "   (X   X)  ", "   |  v  |  ", "    \\___/   ", "   /|   |\\ "]
    // Chapter I: notable enemies
    | "goblin"      => ["    (^_^)   ", "   \\|___|/  ", "    |   |   ", "   / \\ / \\  "]
    | "wolf"        => ["   ,v.v,   ", "  (> . <)  ", "   )   (   ", "   mm mm   "]
    | "bog_witch"   => ["   /^.^\\   ", "  ( -.- )  ", "   |\\|/|   ", "   |   |   "]
    | "orc"         => ["  {O   O}  ", "  | \\^/ |  ", "   \\   /   ", "   |___|   "]
    | "troll_brute" => ["  {O     O}", "  |   !   |", "   \\  W  / ", "   |     | "]
    // Chapter II: undead
    | "skeleton"    => ["   _+_   ", "  (x.x)  ", "  /| |\\  ", "   | |   "]
    | "shadow"      => ["  ~   ~  ", " (~.~)   ", "  |||||  ", "   | |   "]
    | "vampire"     => ["  ,*-*,  ", "  (>.>)  ", "  /|O|\\  ", "   | |   "]
    | "guardian"    => ["  [|||]  ", "  (X.X)  ", "  /|+|\\  ", "  |___|  "]
    // Chapter III: earth and stone
    | "cave_troll"  => ["  ,--,   ", " (0  0)  ", " /|##|\\  ", " [_____] "]
    | "rock_elem"   => ["  ###    ", " (#.#)   ", " |###|   ", " [___]   "]
    | "magma_crab"  => ["  /VVV\\  ", " (o. .o) ", " |=====| ", " //   \\\\ "]
    | "lava_wurm"   => ["   ~^^^~ ", "  (O.O)  ", "  ))|(( ", "  \\/|\\/  "]
    | "earth_titan" => ["  ######  ", "  #O  O#  ", "  # -- #  ", "  ######  ", "  ##  ##  "]
    // Chapter IV: fire and darkness
    | "hellhound"   => ["   .v.v.  ", "  (>..<)  ", "  ))   (( ", "  mm  mm  "]
    | "inf_drake"   => ["   /^-^\\   ", "  / 0.0 \\  ", " < >   < > ", "  \\_____/  ", "  //   \\\\ "]
    | "chaos_witch" => ["  ,*^*,  ", "  (*.*) ", "  /|+|\\  ", "  |   |  "]
    | "nightmare"   => ["  /\\  /\\  ", " ( 0  0)  ", "  \\====/ ", "   ||||  "]
    | "void_stalker"=> ["  ... ..  ", "  .X..X.  ", "  ......  ", "  . .. .  "]
    // Chapter V: sanctum elite
    | "lich_guard"  => ["  [=|=]  ", "  (X X)  ", "  /|#|\\  ", "  |___|  "]
    | "death_kn"    => ["  [|||]  ", "  (=X=)  ", "  /|+|\\  ", "  [___]  "]
    | "bone_dragon" => ["  /^___^\\  ", " ( X . X ) ", "  |     |  ", "  \\/   \\/  ", "  //   \\\\ "]
    | "dark_pal"    => ["  [###]  ", "  (X.X)  ", "  |[*]|  ", "  [___]  "]
    | "undead_drag" => ["  /^===^\\  ", " ( X . X ) ", "  |=====|  ", "  \\/   \\/  ", "  //   \\\\ "]
    | "lich_aspect" => ["    __---__ ", "   (X     X)", "   |  -=-  |", "    \\-----/ ", "   /|     |\\ "]
    | _             => ["  ~^^^~  ", "  (o.o)  ", "   )|(   ", "  [___]  "]
  }
}

@intent "5-line ASCII portrait for each party member — match on name"
@pure @total
fn hero_art :: (name: string) -> string[] {
  match name {
    | "Aria"   => [
        "   ,*,   ",
        "  (o.o)  ",
        "  /|~|\\  ",
        "  // \\\\ "
      ]
    | "Theron" => [
        "  [| |]  ",
        "  (=.=)  ",
        "  |[#]|  ",
        "  [___]  "
      ]
    | "Lyra"   => [
        "   /^\\   ",
        "  (-_-)  ",
        "   >|<   ",
        "  / | \\  "
      ]
    | _ => ["  [???]  "]
  }
}

@pure @total
fn hero_art_mini :: (name: string) -> string {
  match name {
    | "Aria"   => "(o.o)"
    | "Theron" => "(=.=)"
    | "Lyra"   => "(-_-)"
    | _        => "(?.?)"
  }
}

@intent "Short ASCII icon for each item/equipment ID — shown in shop and on hero cards"
@pure @total
fn equip_icon :: (id: string) -> string {
  match id {
    // Weapons — tier 1 (icons are always 4 chars for column alignment)
    | "iron_sword"    => "[/] "
    | "app_staff"     => "[i] "
    | "shortbow"      => "[)] "
    // Weapons — tier 2
    | "steel_sword"   => "[S] "
    | "arcane_staff"  => "[|] "
    | "longbow"       => "[D] "
    // Weapons — tier 3
    | "silver_blade"  => "[*] "
    | "arcane_tome"   => "[T] "
    | "hunter_bow"    => "[>] "
    // Weapons — tier 4
    | "dragon_sword"  => "[X] "
    | "soul_staff"    => "[S] "
    | "storm_bow"     => "[Z] "
    // Armor — tier 2
    | "chainmail"     => "[#] "
    | "silk_robe"     => "[~] "
    | "ranger_vest"   => "[^] "
    // Armor — tier 3
    | "battle_plate"  => "[=] "
    | "void_robe"     => "[V] "
    | "elven_cloak"   => "[>] "
    // Armor — tier 4
    | "dragon_scale"  => "[X] "
    | "archmage_robe" => "[M] "
    | "shadow_cloak"  => "[s] "
    // Consumables — healing
    | "minor_pot"     => "(o) "
    | "major_pot"     => "(.) "
    | "mega_pot"      => "(O) "
    | "tonic"         => "[t] "
    | "elixir"        => "[E] "
    // Consumables — revival (avoid {ident} — Synth treats that as interpolation)
    | "phoenix"       => "<+> "
    | "phoenix_fth"   => "<*> "
    // Consumables — offensive
    | "fire_scroll"   => "[F] "
    | "thunder_orb"   => "[Z] "
    | "inferno"       => "[B] "
    | _               => "[ ] "
  }
}

@intent "Weapon and armor line with ASCII icons for the town party panel"
@pure @total
fn format_equip_with_icons :: (hero: Hero) -> string {
  let wIcon = hero.weapon?.id ? equip_icon(hero.weapon.id) : "--- "
  let aIcon = hero.armor?.id  ? equip_icon(hero.armor.id)  : "--- "
  let wName = hero.weapon?.name ?? "bare hands"
  let aName = hero.armor?.name  ?? "no armor"
  "{wIcon}{wName}  ·  {aIcon}{aName}"
}

@intent "Chapter label for each stage group — bosses get a special prefix"
@pure @total
fn stage_name :: (stageNum: int) -> string {
  let chapter = stageNum < 10 ? "Ch.I  The Wilds"
              : stageNum < 20 ? "Ch.II  The Ruins"
              : stageNum < 30 ? "Ch.III The Deep"
              : stageNum < 40 ? "Ch.IV  The Abyss"
              :                 "Ch.V   The Sanctum"
  let bossTag = (stageNum === 9 || stageNum === 19 || stageNum === 29 || stageNum === 39 || stageNum === 49)
    ? "  [BOSS]"
    : ""
  let displayNum = stageNum + 1
  "{chapter} — Stage {displayNum}/50{bossTag}"
}

